---
import '../../../styles/theme.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WorkNavigator from '../../../components/WorkNavigator.astro';
import { getWorks, getChapters } from '../../../utils/works';

export async function getStaticPaths() {
  const works = await getWorks();
  return works.map((w) => ({
    params: { work: w.slug },
    props: { work: w },
  }));
}

const { work } = Astro.props;
const chapters = await getChapters(work.slug);
const base = import.meta.env.BASE_URL;
const theme = work.data.defaultThemePalette;
---
<BaseLayout title={work.data.title} theme={theme} pageTitle={work.data.title} description={work.data.summary}>
  <main class="work-home container" style="padding: 2.5rem 1.2rem 4rem; max-width: 980px; margin: 0 auto;">
    <p style="color:var(--text-muted); margin-bottom: 0.3em;">
      <a href={base + 'works/'}>← 所有作品</a>
    </p>
    <h1 style="margin-top: 0.2em; font-size: 2.2rem;">{work.data.title}</h1>
    {work.data.summary && <p style="font-size: 1.1rem; color: var(--text-muted);">{work.data.summary}</p>}
    {work.data.tags.length > 0 && (
      <p style="margin: 0.8rem 0;">
        {work.data.tags.map((t) => <span class="tag">{t}</span>)}
      </p>
    )}

    <WorkNavigator currentWorkSlug={work.slug} />

    <h2>章节目录（{chapters.length}）</h2>
    <ol class="chapter-list">
      {chapters.map((c, i) => {
        const slug = c.id.split('/').slice(1).join('/').replace(/\.(mdx|md)$/, '');
        const href = base + 'works/' + work.slug + '/' + slug + '/';
        return (
          <li>
            <a href={href}>
              <span class="ch-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="ch-body">
                <strong>{c.data.title}</strong>
                {c.data.summary && <small>{c.data.summary}</small>}
                {c.data.tags.length > 0 && (
                  <span class="ch-tags">{c.data.tags.slice(0, 4).map((t) => <span class="tag">{t}</span>)}</span>
                )}
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </main>
</BaseLayout>

<style>
  .chapter-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 3rem;
  }
  .chapter-list li {
    margin-bottom: 0.6rem;
  }
  .chapter-list a {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    color: var(--text-main);
    text-decoration: none;
    transition: all 0.18s ease;
    align-items: start;
  }
  .chapter-list a:hover {
    transform: translateX(4px);
    border-color: var(--accent-primary);
    text-decoration: none;
  }
  .ch-num {
    font-weight: 800;
    color: var(--accent-primary);
    font-size: 1.2rem;
    font-variant-numeric: tabular-nums;
  }
  .ch-body { display: flex; flex-direction: column; gap: 0.3rem; }
  .ch-body small { color: var(--text-muted); font-size: 0.9em; }
  .ch-tags { margin-top: 0.2rem; display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .tag {
    display: inline-block;
    font-size: 0.75em;
    padding: 0.15em 0.6em;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-primary) 18%, transparent);
    color: var(--accent-primary);
    border: 1px solid color-mix(in srgb, var(--accent-primary) 40%, transparent);
  }
</style>
