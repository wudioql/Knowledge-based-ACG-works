---
import '../../styles/theme.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkNavigator from '../../components/WorkNavigator.astro';
import { getWorks, getChapters } from '../../utils/works';

const works = await getWorks();
const base = import.meta.env.BASE_URL;

const worksWithChapters = await Promise.all(
  works.map(async (w) => {
    const chapters = await getChapters(w.slug);
    return { work: w, chapterCount: chapters.length };
  }),
);
---
<BaseLayout title="作品列表 · ACG Wiki" theme="ocean" pageTitle="所有作品">
  <main class="container" style="padding: 2.5rem 1.2rem 4rem; max-width: 1100px; margin: 0 auto;">
    <p style="color:var(--text-muted); margin-bottom: 0.3em;"><a href={base}>← 返回首页</a></p>
    <h1 style="margin-top: 0.2em;">作品列表</h1>
    <p>目前收录 <strong>{works.length}</strong> 部作品，按作品 → 章节的层级组织。</p>

    <WorkNavigator />

    <div class="works-grid">
      {worksWithChapters.map(({ work, chapterCount }) => {
        const href = base + 'works/' + work.slug + '/';
        return (
          <a class="work-card" href={href}>
            <div class="work-card-cover">
              <span class="work-card-initials">{work.data.title.slice(0, 2)}</span>
            </div>
            <div class="work-card-body">
              <h3>{work.data.title}</h3>
              {work.data.summary && <p>{work.data.summary}</p>}
              <div class="work-card-meta">
                <span class="tag">📚 {chapterCount} 章</span>
                {work.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>

<style>
  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
    margin-top: 1.5rem;
  }
  .work-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    color: var(--text-main);
  }
  .work-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-hover);
    text-decoration: none;
  }
  .work-card-cover {
    aspect-ratio: 16/9;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent-primary) 35%, var(--bg-color)), color-mix(in srgb, var(--accent-secondary) 30%, var(--bg-color)));
  }
  .work-card-initials { font-size: 2.2rem; font-weight: 900; color: white; letter-spacing: 0.05em; }
  .work-card-body { padding: 1.2rem 1.4rem 1.4rem; }
  .work-card-body h3 { margin: 0 0 0.4rem; font-size: 1.15rem; font-weight: 700; }
  .work-card-body p { margin: 0 0 0.8rem; color: var(--text-muted); font-size: 0.92em; line-height: 1.6; }
  .work-card-meta { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .tag {
    display: inline-block; font-size: 0.75em; padding: 0.2em 0.7em;
    border-radius: 999px; background: color-mix(in srgb, var(--accent-primary) 18%, transparent);
    color: var(--accent-primary); border: 1px solid color-mix(in srgb, var(--accent-primary) 40%, transparent);
  }
</style>
