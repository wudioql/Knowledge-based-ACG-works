---
export interface Props {
  title?: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---
<div class="mdx-card">
  {title && <h4>{title}</h4>}
  {subtitle && <p class="mdx-card-sub">{subtitle}</p>}
  <slot />
</div>

<style>
  .mdx-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 1.2rem 1.4rem;
    margin: 1.2rem 0;
  }
  .mdx-card h4 {
    margin: 0 0 0.3rem;
    color: var(--accent-primary);
    border: none;
    padding: 0;
    font-size: 1.05rem;
  }
  .mdx-card-sub {
    color: var(--text-muted);
    margin: 0 0 0.6rem;
    font-size: 0.9em;
  }
</style>
