---
// 图片网格 — 接收若干 <img> 子标签；也支持传入 <MdxImage>
export interface Props {
  columns?: number;
  gap?: string;
}
const { columns = 3, gap = '1rem' } = Astro.props;
---
<div class="gallery-grid" style={`--col: ${columns}; --gap: ${gap}`}>
  <slot />
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(var(--col), minmax(0, 1fr));
    gap: var(--gap);
    margin: 1.4rem 0;
  }
  @media (max-width: 720px) {
    .gallery-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .gallery-grid :global(figure),
  .gallery-grid :global(.mdx-figure),
  .gallery-grid :global(img) {
    margin: 0;
    width: 100%;
  }
</style>
