---
export interface Props {
  date?: string;
  title?: string;
  year?: string | number;
}
const { date, title, year } = Astro.props;
---
<div class="timeline-node">
  <div class="t-dot" aria-hidden="true"></div>
  <div class="t-body">
    {year !== undefined && <span class="t-year">{year}</span>}
    {title && <h4>{title}</h4>}
    {date && <small>{date}</small>}
    <div class="t-content"><slot /></div>
  </div>
</div>

<style>
  .timeline-node {
    position: relative;
    padding-left: 0.5rem;
    margin: 0 0 2rem;
  }
  .t-dot {
    position: absolute;
    left: -1.85rem;
    top: 0.65rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent-primary);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent-primary) 18%, transparent);
  }
  .t-year {
    display: inline-block;
    font-size: 0.8em;
    font-weight: 700;
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 18%, transparent);
    padding: 0.2em 0.8em;
    border-radius: 999px;
    margin-bottom: 0.4rem;
  }
  .t-body h4 {
    margin: 0.2rem 0;
    border: none;
    padding: 0;
    font-size: 1.1rem;
    color: var(--text-main);
  }
  .t-body small {
    display: block;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    font-size: 0.85em;
  }
  .t-content { color: var(--text-main); line-height: 1.7; font-size: 0.96em; }
</style>
