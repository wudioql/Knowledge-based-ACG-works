---
// 通过 Astro 内置 <Image> 提供 AVIF/WebP 响应式图片、尺寸信息与懒加载
// 允许 MDX 中以 <MdxImage src="../assets/xxx.png" alt="..." /> 使用
// 或通过 MDXComponents 映射默认 <img>
import { Image } from 'astro:assets';

export interface Props {
  src: string | { default: ImageMetadata };
  alt: string;
  width?: number;
  height?: number;
  caption?: string;
}

const { src, alt, width, height, caption } = Astro.props;

// 支持传入字符串路径或 import 的对象形式
let resolved: any = src;
if (typeof src === 'object' && src && 'default' in src) {
  resolved = (src as any).default;
}
---
<figure class="mdx-figure">
  <Image
    src={resolved}
    alt={alt}
    widths={[320, 640, 960, 1280]}
    sizes="(max-width: 640px) 92vw, (max-width: 1100px) 60vw, 720px"
    loading="lazy"
    decoding="async"
    format={['avif', 'webp']}
    quality={82}
    {...width ? { width } : {}}
    {...height ? { height } : {}}
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .mdx-figure {
    margin: 1.6rem 0;
    padding: 0;
    text-align: center;
  }
  .mdx-figure :global(img) {
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow);
    max-width: 100%;
    height: auto;
  }
  figcaption {
    margin-top: 0.6em;
    color: var(--text-muted);
    font-size: 0.88em;
    font-style: italic;
  }
</style>
